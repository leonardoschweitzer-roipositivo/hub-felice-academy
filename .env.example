# ===========================================================================
# Variáveis de ambiente do hub Felice. Copie para .env.local e preencha.
# Não commitar segredos (o .env*.local é gitignored).
# ===========================================================================

# --- Chat Kit F4 (Gemini) ---
GEMINI_API_KEY=
# KITF4_CHAT_MODEL=gemini-2.0-flash

# --- Tracking Meta (Pixel + Conversions API) ---

# ID do Pixel "masterclass pixel" — público; o mesmo no browser e no CAPI.
NEXT_PUBLIC_META_PIXEL_ID=1608754590127302

# Versão da Graph API. Confirmar a vigente em developers.facebook.com.
GRAPH_VERSION=v21.0

# Domínio canônico (sem barra no fim) — usado no event_source_url dos eventos.
SITE_URL=https://www.feliceacademy.com.br

# Token do CAPI: Events Manager > Configurações > Conversions API >
# "Gerar token de acesso" (deste pixel). SECRETO.
META_CAPI_TOKEN=

# Token combinado com o Green p/ validar o webhook de venda. SECRETO.
# Enviar como header `x-green-token`, `Authorization: Bearer …` ou `?token=`.
GREEN_WEBHOOK_TOKEN=

# Código de teste do Events Manager (aba Test Events). SÓ em teste —
# deixar vazio em produção (senão os eventos não contam de verdade).
META_TEST_EVENT_CODE=

# (Opcional) Webhook para onde os leads de consultoria são repassados
# (CRM, Zapier, Make, planilha…). Sem ele, o lead só é logado no servidor.
LEAD_WEBHOOK_URL=

# --- WhatsApp API Oficial (Meta Cloud API) — módulo Vendas ---
# Hoje o Atendimento/Automação rodam em modo MOCK (lib/whatsapp/client.ts).
# Preencher quando ligar a API Oficial; nada disso é necessário pro mock.
#
# Token permanente do app do WhatsApp (System User). SECRETO.
WHATSAPP_TOKEN=
# ID do número de telefone (Phone Number ID) do WhatsApp Business.
WHATSAPP_PHONE_ID=
# Token de verificação do webhook (você define; usado no handshake da Meta).
WHATSAPP_VERIFY_TOKEN=
